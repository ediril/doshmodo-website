RewriteEngine On

ErrorDocument 404 /404.php

# Force HTTPS redirect
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.doshmodo\.com$ [NC]
RewriteRule ^(.*)$ https://doshmodo.com/$1 [L,R=301]

# Only allow doshmodo.com (non-www)
RewriteCond %{HTTP_HOST} !^doshmodo\.com$ [NC]
RewriteRule ^ - [R=404,L]

# Redirect .php extension to clean URLs
RewriteCond %{THE_REQUEST} /([^?\s]*?)\.php[\s?] [NC]
RewriteRule ^ /%1? [R=301,L]

# Remove .php extension from URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# If the requested file or directory exists, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Unknown clean URLs should return 404 instead of showing the homepage.
RewriteRule ^ - [R=404,L]

# Allow direct access to static files
<FilesMatch "\.(css|js|jpg|jpeg|png|gif|ico)$">
    Order allow,deny
    Allow from all
</FilesMatch>

# PHP settings
<IfModule mod_php.c>
    php_flag display_errors On
    php_value error_reporting E_ALL
</IfModule>